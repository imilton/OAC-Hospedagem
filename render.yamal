databases:
  - name: oac-hospedagem-db
    plan: free
    databaseName: hospedagem
    user: oac

services:
  - type: web
    name: oac-hospedagem
    runtime: python
    plan: free
    buildCommand: pip install -r requirements.txt
    startCommand: gunicorn run:app --bind 0.0.0.0:$PORT
    envVars:
      - key: DATABASE_URL
        fromDatabase:
          name: oac-hospedagem-db
          property: connectionString
      - key: SECRET_KEY
        generateValue: true